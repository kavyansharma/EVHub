rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Safe helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function userExists() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return userExists() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : {};
    }

    function hasRole(role) {
      return userExists() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isPartner() {
      return hasRole('partner');
    }

    // ─────────────────────────────────────────────────────────
    // USERS COLLECTION (/users/{uid})
    // ─────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();

      // Users can create their own profile document
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Users can update their own profile (or admin can update any)
      allow update: if isAdmin() || (
        isAuthenticated() && request.auth.uid == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || resource.data.role == request.resource.data.role)
      );

      allow delete: if isAdmin();

      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // ─────────────────────────────────────────────────────────
    // CHARGERS COLLECTION (/chargers/{chargerId})
    // ─────────────────────────────────────────────────────────
    match /chargers/{chargerId} {
      // READ RULES:
      // • Authenticated users can read all chargers
      // • Public/Unauthenticated can read verified & approved chargers
      // • Fallback timestamp for dev
      allow read: if isAuthenticated()
        || resource.data.isVerified == true 
        || request.time < timestamp.date(2026, 8, 14);

      // CREATE RULES:
      // • Admin can create any charger with verified status
      // • Partner can create chargers owned by themselves with pending status
      allow create: if isAdmin() || (
        isPartner() 
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.isVerified == false
        && request.resource.data.verificationStatus == 'pending'
      ) || request.time < timestamp.date(2026, 8, 14);

      // UPDATE RULES:
      // • Admin can update all fields (including verification)
      // • Partner can update own chargers, but CANNOT alter verification status
      allow update: if isAdmin() || (
        isPartner()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.isVerified == resource.data.isVerified
        && request.resource.data.verificationStatus == resource.data.verificationStatus
      ) || request.time < timestamp.date(2026, 8, 14);

      // DELETE RULES:
      // • Admin can delete any charger
      // • Partner can delete only their own chargers
      allow delete: if isAdmin() || (
        isPartner() && resource.data.ownerId == request.auth.uid
      ) || request.time < timestamp.date(2026, 8, 14);
    }

    // ─────────────────────────────────────────────────────────
    // IMPORT JOBS COLLECTION (/import_jobs/{jobId})
    // ─────────────────────────────────────────────────────────
    match /import_jobs/{jobId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Fallback rule for other collections (wallets, sessions, etc.)
    match /{document=**} {
      allow read, write: if isAuthenticated() || request.time < timestamp.date(2026, 8, 14);
    }
  }
}

